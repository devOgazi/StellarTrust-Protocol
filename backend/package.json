{
  "name": "@stellartrust/backend",
  "version": "0.1.0",
  "private": true,
  "description": "StellarTrust Protocol backend API service",
  "scripts": {
    "dev": "ts-node-dev --respawn src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest --forceExit --testTimeout=30000",
    "test:unit": "jest --testPathPattern=unit --forceExit",
    "test:integration": "jest --testPathPattern=integration --forceExit --testTimeout=30000",
    "test:e2e": "jest --testPathPattern=e2e --forceExit",
    "test:coverage": "jest --coverage --forceExit",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "lint": "eslint 'src/**/*.ts'",
    "format": "prettier --write 'src/**/*.ts'"
  },
  "dependencies": {
    "@stellar/stellar-sdk": "^12.0.0",
    "@prisma/client": "^5.0.0",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "redis": "^4.6.0",
    "ipfs-http-client": "^60.0.0",
    "jsonwebtoken": "^9.0.0",
    "dotenv": "^16.0.0",
    "zod": "^3.22.0",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/supertest": "^6.0.0",
    "typescript": "^5.3.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "jest": "^29.0.0",
    "@types/jest": "^29.0.0",
    "ts-jest": "^29.0.0",
    "supertest": "^6.3.3",
    "prisma": "^5.0.0",
    "eslint": "^8.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "prettier": "^3.0.0"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.ts",
      "**/*.test.ts",
      "**/*.spec.ts"
    ],
    "moduleNameMapper": {
      "^@/(.*)$": "<rootDir>/src/$1"
    },
    "transform": {
      "^.+\\.tsx?$": ["ts-jest", {
        "tsconfig": {
          "strictNullChecks": true,
          "esModuleInterop": true
        }
      }]
    },
    "globals": {}
  }
}
