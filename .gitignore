# =============================================================================
# StellarTrust Protocol — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# Rust / Cargo (contracts/)
# -----------------------------------------------------------------------------
contracts/target/
target/
**/*.rs.bk
Cargo.lock.bak

# Soroban test snapshots (generated automatically by soroban-sdk testutils)
**/test_snapshots/

# Compiled WASM artifacts
**/*.wasm

# -----------------------------------------------------------------------------
# Node.js (backend/, frontend/, sdk/)
# -----------------------------------------------------------------------------
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/
.yarn/

# Build output
dist/
build/
out/
.next/
.turbo/

# Type-check cache
*.tsbuildinfo

# -----------------------------------------------------------------------------
# Environment / secrets
# -----------------------------------------------------------------------------
.env
.env.*
!.env.example
!.env.*.example

# -----------------------------------------------------------------------------
# Database / Prisma
# -----------------------------------------------------------------------------
*.db
*.sqlite
*.sqlite3
prisma/migrations/dev.db

# -----------------------------------------------------------------------------
# Docker
# -----------------------------------------------------------------------------
.docker/

# -----------------------------------------------------------------------------
# Editors & IDEs
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# -----------------------------------------------------------------------------
# Logs & runtime
# -----------------------------------------------------------------------------
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# -----------------------------------------------------------------------------
# Coverage & test output
# -----------------------------------------------------------------------------
coverage/
.nyc_output/
lcov.info
tarpaulin-report.html

# -----------------------------------------------------------------------------
# OS
# -----------------------------------------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Desktop.ini

# -----------------------------------------------------------------------------
# Misc
# -----------------------------------------------------------------------------
*.bak
*.tmp
*.orig
